{
  "name": "ReMind",
  "private": true,
  "version": "0.0.9",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "vite",
    "dev:backend": "python3 main.py",
    "docker:dev": "docker compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up --build",
    "build": "vite build",
    "typecheck:base": "tsc -p tsconfig.json --noEmit --noUnusedLocals --noUnusedParameters",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "typecheck": "npm run typecheck:base && npm run typecheck:strict",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "commit-and-tag-version",
    "openapi:generate": "python3 scripts/generate_openapi_ts.py",
    "openapi:check": "python3 scripts/generate_openapi_ts.py --check",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "commit-and-tag-version": {
    "infile": "docs/CHANGELOG.md"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "chart.js": "^4.4.0",
    "d3": "^7.8.5",
    "dompurify": "^3.3.4",
    "i18next": "^25.7.3",
    "katex": "^0.16.25",
    "lucide-react": "^0.555.0",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.14.0",
    "nomnoml": "^1.7.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.0"
  },
  "overrides": {
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3": "^7.4.3",
    "@types/katex": "^0.16.7",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.8.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  }
}
